<?xml version="1.0" encoding="UTF-8"?>
<configuration scan="true" scanPeriod="30 seconds">

    <!-- =========================================================
         LOCAL DEVELOPMENT
    ========================================================== -->
    <springProfile name="!docker">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>
                    %d{yyyy-MM-dd HH:mm:ss.SSS}
                    [%thread]
                    %-5level
                    %logger{36}
                    traceId=%X{traceId:-N/A}
                    spanId=%X{spanId:-N/A}
                    correlationId=%X{correlationId:-N/A}
                    - %msg%n
                </pattern>
                <charset>UTF-8</charset>
            </encoder>
        </appender>

        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>

        <logger name="com.luciodowglas.userapi"
                level="DEBUG"
                additivity="false">
            <appender-ref ref="CONSOLE"/>
        </logger>
    </springProfile>

    <!-- =========================================================
         DOCKER / PRODUCTION
    ========================================================== -->
    <springProfile name="docker">
        <!-- Structured JSON logs -->
        <appender name="JSON_CONSOLE"  class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <customFields>
                    {
                    "application":"user-api",
                    "environment":"docker",
                    "host":"${HOSTNAME:-unknown}"
                    }
                </customFields>

                <includeMdcKeyName>traceId</includeMdcKeyName>
                <includeMdcKeyName>spanId</includeMdcKeyName>
                <includeMdcKeyName>correlationId</includeMdcKeyName>

                <shortenedLoggerNameLength>
                    36
                </shortenedLoggerNameLength>

                <throwableConverter
                        class="net.logstash.logback.stacktrace.ShortenedThrowableConverter">

                    <maxDepthPerCause>10</maxDepthPerCause>
                    <rootCauseFirst>true</rootCauseFirst>

                </throwableConverter>

            </encoder>
        </appender>

        <!-- Loki -->
        <appender name="LOKI"
                  class="com.github.loki4j.logback.Loki4jAppender">

            <http>
                <url>
                    http://loki:3100/loki/api/v1/push
                </url>

                <connectionTimeoutMs>5000</connectionTimeoutMs>
                <requestTimeoutMs>5000</requestTimeoutMs>
            </http>

            <format>

                <label>
                    <pattern>
                        job=user-api,
                        application=user-api,
                        env=docker,
                        host=${HOSTNAME:-unknown},
                        level=%level
                    </pattern>

                    <nopex>true</nopex>
                </label>

                <message>
                    <pattern>
                        ts=%d{yyyy-MM-dd'T'HH:mm:ss.SSS}
                        lvl=%-5level
                        app=user-api
                        host=${HOSTNAME:-unknown}
                        trc=%X{traceId:-N/A}
                        spn=%X{spanId:-N/A}
                        cor=%X{correlationId:-N/A}
                        lgr=%logger{36}
                        msg="%replace(%msg){'["\n\r\t]',' '}"%n%ex{10}
                    </pattern>
                </message>

                <sortByTime>true</sortByTime>

            </format>
        </appender>

        <!-- Non-blocking async wrapper -->
        <appender name="LOKI_ASYNC"
                  class="ch.qos.logback.classic.AsyncAppender">

            <appender-ref ref="LOKI"/>

            <queueSize>8192</queueSize>
            <discardingThreshold>0</discardingThreshold>
            <neverBlock>true</neverBlock>

        </appender>

        <root level="INFO">
            <appender-ref ref="JSON_CONSOLE"/>
            <appender-ref ref="LOKI_ASYNC"/>
        </root>

        <!-- INFO in production -->
        <logger name="com.luciodowglas.userapi"
                level="INFO"
                additivity="false">

            <appender-ref ref="JSON_CONSOLE"/>
            <appender-ref ref="LOKI_ASYNC"/>

        </logger>

    </springProfile>

    <!-- =========================================================
         NOISY LIBS
    ========================================================== -->

    <logger name="org.springframework.security" level="WARN"/>
    <logger name="org.hibernate.SQL" level="WARN"/>
    <logger name="org.springframework.web" level="WARN"/>
    <logger name="org.springframework.web.servlet.DispatcherServlet" level="WARN"/>
    <logger name="io.github.resilience4j" level="WARN"/>
    <logger name="org.springframework.boot.actuate" level="WARN"/>
    <logger name="com.github.loki4j" level="WARN"/>

</configuration>
